FASTMCP_STATELESS_HTTP=true

# Capa de datos relacional.
# Valores soportados: sqlite, sqlalchemy, relational, postgres, postgresql, mysql
REPO_TYPE=sqlite

# SQLite local por defecto. Si DATABASE_URL está definido, tiene prioridad.
SQLITE_PATH=medical_ecg.db
# DATABASE_URL=sqlite:///medical_ecg.db

# PostgreSQL: requiere psycopg
# REPO_TYPE=postgresql
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/medical_ecg

# MySQL: requiere PyMySQL
# REPO_TYPE=mysql
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/medical_ecg

API_PORT=5000
MCP_PORT=9000
